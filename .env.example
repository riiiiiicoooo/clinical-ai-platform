# Clinical AI Platform — Environment Configuration
# NEVER commit the actual .env file

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://localhost:5432/clinical_ai
DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379/0

# FHIR / EHR Integration (Epic SMART on FHIR)
FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
FHIR_CLIENT_ID=
FHIR_CLIENT_SECRET=

# LLM Provider (Claude Enterprise with BAA)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Medical Ontologies
UMLS_API_KEY=

# Auth (Clerk)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Document Storage (S3 encrypted)
S3_BUCKET=meridian-clinical-ai-docs
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Observability (LangSmith)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=clinical-ai-platform

# HIPAA Compliance
PHI_ENCRYPTION_KEY=
AUDIT_LOG_RETENTION_YEARS=6
SESSION_TIMEOUT_MINUTES=30
